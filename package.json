{
  "name": "orion-kit",
  "author": "Martin Linde Persson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mumma6/orion-kit"
  },
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "db:generate": "pnpm --filter @workspace/database db:generate",
    "db:migrate": "pnpm --filter @workspace/database db:migrate",
    "db:push": "pnpm --filter @workspace/database db:push",
    "db:pull": "pnpm --filter @workspace/database db:pull",
    "db:studio": "pnpm --filter studio dev",
    "db:check": "pnpm --filter @workspace/database db:check",
    "db:seed": "pnpm --filter @workspace/database db:seed",
    "stripe:listen-dev": "stripe listen --forward-to localhost:3002/webhooks/stripe",
    "typecheck": "turbo typecheck",
    "prepare": "lefthook install",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@playwright/test": "^1.56.0",
    "@types/node": "^24.7.2",
    "@vitest/ui": "^3.2.4",
    "@workspace/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lefthook": "^2.1.4",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "typescript": "5.7.3",
    "ultracite": "7.4.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=20"
  },
  "catalogs": {
    "schemas": {
      "drizzle-zod": "^0.8.3",
      "drizzle-kit": "^0.31.10",
      "drizzle-orm": "^0.45.2",
      "zod": "^4.3.6"
    },
    "web": {
      "next": "^16.1.0",
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    },
    "data-layer": {
      "@orpc/tanstack-query": "^1.13.13",
      "@tanstack/react-query": "^5.96.2"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@t3-oss/env-nextjs": "^0.13.11",
    "root": "tanstack/react-query"
  }
}
