# App Application Environment Variables
# Copy to apps/app/.env.local

# =============================================================================
# APP API URL (apps/app/keys.ts)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3002

# =============================================================================
# DATABASE (packages/database)
# =============================================================================
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# =============================================================================
# AUTHENTICATION (packages/auth — Clerk)
# =============================================================================
CLERK_SECRET_KEY=sk_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# =============================================================================
# APP URLS (packages/payment)
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3001

# =============================================================================
# STRIPE PAYMENTS (packages/payment)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_ID_ENTERPRISE=price_...

# =============================================================================
# AXIOM OBSERVABILITY (packages/observability)
# =============================================================================
NEXT_PUBLIC_AXIOM_TOKEN=xaat-...
NEXT_PUBLIC_AXIOM_DATASET=orion-kit

# =============================================================================
# POSTHOG ANALYTICS (packages/analytics)
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
